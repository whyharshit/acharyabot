# ============================================================================
# Farmer Acharya app - environment variables
# ============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Which Acharya this deployment represents.
NEXT_PUBLIC_ACHARYA_SLUG=farmer
NEXT_PUBLIC_ACHARYA_SCHEMA=acharya_farmer

# Development convenience. When true, any valid Indian phone entered during
# pilot login is auto-created in farmer_users. Set false for production.
AUTO_CREATE_PILOT_USERS=true

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google TTS - learner voice.
GOOGLE_TTS_KEY=your-google-tts-key-here

# Optional Gemini Live voice mode.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Optional live mandi prices via data.gov.in.
DATA_GOV_API_KEY=your-data-gov-key-here

# Admin login credentials for /admin.
NEXT_PUBLIC_ADMIN_EMAIL=admin@farmer-acharya.app
ADMIN_PASSWORD=change-this-admin-password

# Session secret - HMAC key for signing Farmer Acharya session cookies.
SESSION_SECRET=change-me-to-a-long-random-string
