# ============================================================================
# Arjun Acharya app — environment variables
# ============================================================================
# After migration to the Gurukul schema, Arjun points at the OMNIDEL Supabase
# project (jfbadheqtxzjkvzgstwl) and uses the `gurukul` schema. Fill the
# omnidel project's URL + service role key below, not Arjun's old project.

# Supabase — the omnidel-platform project (dev today, prod later).
# Schemas: gurukul (identity + content + telemetry), omnidel (ops, added later).
NEXT_PUBLIC_SUPABASE_URL=https://wmiqcagazrixayzgmnws.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Which Acharya this deployment represents (maps to gurukul.acharyas.slug).
NEXT_PUBLIC_ACHARYA_SLUG=arjun

# Anthropic (Claude API) — shared across all Acharyas for now.
# If omitted, chat and quiz fall back to Gemini using GEMINI_API_KEY.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Gemini — Live voice token minting, plus chat/quiz fallback when Anthropic is absent.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_QUIZ_MODEL=gemini-2.5-flash

# Google TTS — learner voice.
GOOGLE_TTS_KEY=your-google-tts-key-here

# Session secret — HMAC key for signing the arjun-learner-session cookie
# (phone OTP login). Any long random string; must be identical across all
# serverless instances and every deploy, otherwise existing sessions break.
SESSION_SECRET=change-me-to-a-long-random-string
